<Window x:Class="RaselPdfPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Rasel Mia PDF Studio Pro" Height="850" Width="1300" 
        Background="#1E1E1E" FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- কাস্টম বাটন স্টাইল -->
        <Style x:Key="ProButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/> 
            <RowDefinition Height="*"/>  
            <RowDefinition Height="30"/> 
        </Grid.RowDefinitions>

        <!-- টপ টুলবার -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#000000" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="10,0">
                    <Button Content="📂 Open" Style="{StaticResource ProButtonStyle}" Click="OpenPdf_Click"/>
                    <Button Content="💾 Save" Style="{StaticResource ProButtonStyle}" Click="SavePdf_Click"/>
                </StackPanel>
                
                <Rectangle Width="1" Fill="#555555" Margin="5,15" DockPanel.Dock="Left"/>

                <TextBlock Text="Rasel PDF Studio - Enterprise Edition" DockPanel.Dock="Right" 
                           Foreground="#888888" VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>   
            </Grid.ColumnDefinitions>

            <!-- লেফট সাইডবার -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">
                    <TextBlock Text="DOCUMENT INFO" Foreground="#888888" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="FileNameText" Text="No file opened" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,20"/>
                </StackPanel>
            </Border>

            <!-- পিডিএফ ক্যানভাস (Syncfusion) -->
            <Border Grid.Column="1" Background="#1A1A1A">
                <syncfusion:PdfViewerControl x:Name="PdfViewer" Margin="10"/>
            </Border>
        </Grid>

        <!-- স্ট্যাটাস বার -->
        <Border Grid.Row="2" Background="#007ACC">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Ready" Foreground="White" Margin="10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Engine: Syncfusion | GitHub Actions Ready" DockPanel.Dock="Right" Foreground="White" Margin="10,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
